@page "/titulos-canciones"
@rendermode InteractiveServer


<div class="container">
    <h2>Titulos de Canciones</h2>

    <div class="d-flex align-items-center justify-content-start m-2 gap-2">
        <label for="txtTitulo" class="w-25">Título de la canción:</label>
        <input id="txtTitulo" class="form-control w-75" type="text" @bind="_tituloCancion" placeholder="Título de la canción" />
    </div>

    <button class="btn btn-primary mt-3" @onclick="Guardar">Guardar</button>

    @if(_indiceEdicion >= 0)
    {
        <div>
            <div class="d-flex justify-content-start align-items-center m-2 gap-1">
                <label for="txtNuevoTitulo" class="w-25">Ingresa nuevo título: </label>
                <input id="txtNuevoTitulo" class="form-control w-50" type="text" @bind="_tituloEditado" placeholder="Ingresa nuevo título de canción"/>

                <button class="btn btn-success" @onclick="Confirmar">Confirmar</button>
                <button class="btn btn-danger" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    <div id="lista" class="mt-3">
        <h3>Lista de canciones</h3>
        <!-- Aquí se mostrarán los títulos de las canciones guardados -->
        <ul class="list-group">
            @for (var i = 0; i < _titulosCanciones.Count; i++)
            {
                int indice = i;
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    @_titulosCanciones[indice]
                    <div>
                        <button class="btn btn-sm btn-danger" @onclick="() => Eliminar(_titulosCanciones[indice])">✖</button>
                        <button class="btn btn-sm btn-info" @onclick="() => Editar(indice)">✎</button>
                    </div>
                </li>
            }
        </ul>
    </div>

</div>

@code {
    private string _tituloCancion = "";
    private int _indiceEdicion = -1;
    private string _tituloEditado = "";
    private List<string> _titulosCanciones = new();


    // Guardar canciones
    private void Guardar()
    {
        // Guardado de la canción
        if (!string.IsNullOrWhiteSpace(_tituloCancion))
        {
            _titulosCanciones.Add(_tituloCancion);
            _tituloCancion = "";
        }
    }

    // Eliminar canciones
    private void Eliminar(string cancion)
    {
        _titulosCanciones.Remove(cancion);
    }

    // Editar título
    private void Editar(int i)
    {
        _indiceEdicion = i;
        _tituloEditado = _titulosCanciones[i];
    }

    // Confirmar edición
    private void Confirmar()
    {
        if(!string.IsNullOrWhiteSpace(_tituloEditado))
        {
            _titulosCanciones[_indiceEdicion] = _tituloEditado;
            _indiceEdicion = -1;
        }
    }

    // Cancelar edición
    private void Cancelar()
    {
        _indiceEdicion = -1;
        _tituloEditado = "";
    }

}
