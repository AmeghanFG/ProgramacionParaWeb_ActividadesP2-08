@page "/ciclos"
@rendermode InteractiveServer

<h3>Ciclos</h3>

<div class="container">
    <div class="row mt-3 align-items-center">
        <div class="col-2">
            <label for="txtEdad" class="col-form-label">Edad: </label>
        </div>
        <div class="col-2">
            <input type="number" id="txtEdad" class="form-control" @bind="_valorCiclo" />
        </div>
    </div>
</div>

<button class="btn btn-primary mt-3" @onclick="Guardar">Guardar</button> <!--Guardar en lugar de saludar-->
<button class="btn btn-primary mt-3" @onclick="Saludar">CiclosEdad</button>
<button class="btn btn-danger mt-3" @onclick="Eliminar">Eliminar</button>
<button class="btn btn-secundary mt-3" @onclick="Existe">Existe</button>
<button class="btn btn-secundary mt-3" @onclick="Limpiar">Limpiar</button>


Calificaciones guardades @_calificaciones.Count <!-- Count para contar-->
<br />
@_calificaciones.ToString();
Encontrado en: @_indice
@if (_calificaciones.Count > 0)
{
    <ul>
        @foreach (var calificacion in _calificaciones.OrderBy(c => c)) // foreach(var calificacion in _calificaciones.Where(c => c > 5))
        {
            <li>@calificacion</li>
        }
    </ul>

    <ul class="mt-3">
        @_mostrar = @_calificaciones.Contains(_valorCiclo);
        <!--Aquí va el for como forma uno, pero menos adecuada para recorrer coleccioes
            Arrobafor (var indice = 0; indice < _calificaciones.Count; indice++)
        {
            <li>Arroba_calificaciones[indice]</li>
        }
        -->
        @foreach(var calificación in _calificaciones)
        {
            <li>@calificación</li>
        }
    </ul>
}

<hr />
Calificaciones guardadas aprobatorias: @_calificaciones.Count(r => r > 5)
@((MarkupString)_letrero) <!--¿Qué hace markupString? Rederizame el contenido de la cadena, muestramelo renderizado como cadena en HTML no como HTML-->

<hr />

@code {
    private int _valorCiclo, _indice;
    private bool _mostrar = false;
    private string _letrero = "";
    private List<int> _calificaciones = new(); // Hay varios tipos de colecciones, esta es LIST, la más sencilla, 

    private void Guardar()
    {

        //_calificaciones.Add(_valorCiclo);
        _calificaciones.Insert(0, _valorCiclo);
        _valorCiclo = 0;

    }

    private void Existe()
    {
        _mostrar = @_calificaciones.Contains(_valorCiclo);
        _letrero = _calificaciones.IndexOf(_valorCiclo).ToString();
    }

    private void Limpiar()
    {
        _calificaciones.Clear();
    }

    private void Eliminar()
    {
        _calificaciones.Remove(_valorCiclo);
    }


    private void Saludar()
    {
        /*_indice = 0;
        _letrero = "<ul class='mt-3'>";
