        {
            _letrero += $"<li> Valor del ciclo: {_indice} </li>";
            _indice++;
            } while (_indice < _valorCiclo);
        while(_indice < _valorCiclo)
        {
            _letrero += $"<li> Valor del ciclo: {_indice} </li>";
            _indice++;
            } */
                                                                // _letrero += "</ul>";

                                                                _letrero = "<ul class='mt-3'>";
        for (var indice = 0; indice < _valorCiclo; indice ++) // Op 2: indice+=2
        {
            // Op 1 if (indice%2 == 0)
            // {

            if (indice == 5)
            {
                continue; // Interrumple la iteración
                // break; Rompe la ejecución
            }
            _letrero += $"<li> Valor del ciclo: {indice} </li>";
            // }
        }
        _letrero += "</ul>";

    }

}

