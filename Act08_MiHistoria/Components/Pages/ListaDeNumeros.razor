@page "/lista-de-numeros"
@rendermode InteractiveServer

<div class="container">
    <div>
        <h1>Lista De Numeros</h1>

        <div class="d-flex align-items-center m-2 gap-2">
            <label for="numero1" class="w-10">Número 1:</label>
            <input id="numero1" class="form-control w-75" type="number" @bind="numero1" placeholder="Número entero" />
        </div>
        <div class="d-flex align-items-center m-2 gap-2">
            <label for="numero2" class="w-10">Número 1:</label>
            <input id="numero2" class="form-control w-75" type="number" @bind="numero2" placeholder="Número entero" />
        </div>

        <button class="btn btn-primary my-3" @onclick="listar">Cacular</button>
    </div>

    <div class="container d-flex mt-3">
        <div id="listaPares" class="container w-50 px-3">
            <h2>Pares</h2>

            <ul class="list-group list-group-flush">
                @((MarkupString)_listaPares)
            </ul>
        </div>

        <div id="listaPares" class="container w-50 px-3">
            <h2>Pares</h2>
            <ul class="list-group list-group-flush">
                @((MarkupString)_listaImpares)
            </ul>
        </div>
    </div>
</div>

@code {
    private int numero1;
    private int numero2;
    private string _listaPares = "";
    private string _listaImpares = "";


    private void listar()
    {
        int numMenor = numero1 < numero2 ? numero1 : numero2;
        int numMayor = numero1 < numero2 ? numero2 : numero1;

        for (int i = numMenor; i <= numMayor; i++)
        {
            if(i % 2 == 0)
            {
                _listaPares += $"<li class='list-group-item'>{i}</li>";
            } else
            {
                _listaImpares += $"<li class='list-group-item'>{i}</li>";
            }

        }
    }

}
